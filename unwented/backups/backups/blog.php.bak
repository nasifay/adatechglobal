<?php
// blog.php - list posts from DB
require_once __DIR__ . '/includes/db.php';
require_once __DIR__ . '/includes/helpers.php';
include __DIR__ . '/partials/header.php';

$stmt = $pdo->query('SELECT id, title, excerpt, image, created_at FROM posts ORDER BY created_at DESC');
$posts = $stmt->fetchAll();
?>

  <main id="main">

    <!-- ======= Blog Section ======= -->
    <section id="recent-blog-posts" class="recent-blog-posts">
      <div class="container" data-aos="fade-up">

        <div class="section-header">
          <h2>Recent Blog Posts</h2>
          <p>Insights, stories, and updates from Adatech Global.</p>
        </div>

        <div class="row gy-5">
          <?php if (empty($posts)): ?>
            <div class="col-12">No posts published yet.</div>
          <?php else: ?>
            <?php foreach ($posts as $post): ?>
              <div class="col-xl-4 col-md-6" data-aos="fade-up">
                <div class="post-item position-relative h-100">
                  <div class="post-img position-relative overflow-hidden">
                    <img src="<?php echo esc($post['image'] ?: 'assets/img/blog/blog-1.jpg'); ?>" class="img-fluid" alt="">
                    <span class="post-date"><?php echo date('M j', strtotime($post['created_at'])); ?></span>
                  </div>
                  <div class="post-content d-flex flex-column">
                    <h3 class="post-title"><?php echo esc($post['title']); ?></h3>
                    <div class="meta d-flex align-items-center">
                      <div class="d-flex align-items-center"><i class="bi bi-person"></i> <span class="ps-2">Adatech Team</span></div>
                    </div>
                    <hr>
                    <a href="blog-details.php?id=<?php echo (int)$post['id']; ?>" class="readmore stretched-link"><span>Read More</span><i class="bi bi-arrow-right"></i></a>
                  </div>
                </div>
              </div>
            <?php endforeach; ?>
          <?php endif; ?>
        </div>

      </div>
    </section><!-- End Blog Section -->

  </main>

<?php include __DIR__ . '/partials/footer.php';

?>
