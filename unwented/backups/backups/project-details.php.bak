<?php
// project-details.php - show a single project by id
require_once __DIR__ . '/includes/db.php';
require_once __DIR__ . '/includes/helpers.php';
include __DIR__ . '/partials/header.php';

$id = isset($_GET['id']) ? (int)$_GET['id'] : null;
if (!$id) {
    header('Location: projects.php');
    exit;
}

$stmt = $pdo->prepare('SELECT * FROM projects WHERE id = ?');
$stmt->execute([$id]);
$project = $stmt->fetch();
if (!$project) {
    echo '<div class="container"><p>Project not found.</p></div>';
    include __DIR__ . '/partials/footer.php';
    exit;
}
?>

  <main id="main">

    <section id="project-details" class="project-details">
      <div class="container" data-aos="fade-up">
        <div class="portfolio-details-container">
          <div class="portfolio-details-img">
            <img src="<?php echo esc($project['image'] ?: 'assets/img/projects/web-platform.jpg'); ?>" class="img-fluid" alt="">
          </div>

          <div class="portfolio-description">
            <h2><?php echo esc($project['title']); ?></h2>
            <p><?php echo nl2br(esc($project['description'])); ?></p>
          </div>

        </div>

        <div class="row justify-content-between gy-4 mt-4">
          <div class="col-lg-8">
            <!-- Additional content could go here -->
          </div>
          <div class="col-lg-3">
            <div class="portfolio-info">
              <h3>Project information</h3>
              <ul>
                <li><strong>Project date</strong> <span><?php echo esc($project['updated_at']); ?></span></li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

<?php include __DIR__ . '/partials/footer.php';

?>
