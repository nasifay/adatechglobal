<?php
// blog-details.php - show a single post by id or slug
require_once __DIR__ . '/includes/db.php';
require_once __DIR__ . '/includes/helpers.php';
include __DIR__ . '/partials/header.php';

$id = isset($_GET['id']) ? (int)$_GET['id'] : null;
$slug = isset($_GET['slug']) ? $_GET['slug'] : null;

if (!$id && !$slug) {
    header('Location: blog.php');
    exit;
}

if ($id) {
    $stmt = $pdo->prepare('SELECT * FROM posts WHERE id = ?');
    $stmt->execute([$id]);
} else {
    $stmt = $pdo->prepare('SELECT * FROM posts WHERE slug = ?');
    $stmt->execute([$slug]);
}
$post = $stmt->fetch();
if (!$post) {
    echo '<div class="container"><p>Post not found.</p></div>';
    include __DIR__ . '/partials/footer.php';
    exit;
}
?>

  <main id="main">

    <section class="blog-details">
      <div class="container" data-aos="fade-up">
        <div class="row">
          <div class="col-lg-8 entries">
            <article class="entry entry-single">
              <div class="entry-img">
                <img src="<?php echo esc($post['image'] ?: 'assets/img/blog/blog-1.jpg'); ?>" alt="" class="img-fluid">
              </div>
              <h2 class="entry-title"><?php echo esc($post['title']); ?></h2>
              <div class="entry-content">
                <?php echo $post['body']; ?>
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>

  </main>

<?php include __DIR__ . '/partials/footer.php';

?>
<?php // blog-details.php - static fallback ?>
